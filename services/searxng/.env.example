# SearXNG environment variables
# Copy to .env and fill in real values (NEVER commit .env)

# Secret key for SearXNG sessions — generate with: openssl rand -hex 32
SEARXNG_SECRET_KEY=change_me_generate_with_openssl_rand_hex_32

# Public URL of this SearXNG instance
# Example: https://search.example.com or http://192.168.1.100:8080
SEARXNG_BASE_URL=http://localhost:8080

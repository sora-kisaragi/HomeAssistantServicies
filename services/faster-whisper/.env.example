# Faster Whisper environment variables
# Copy to .env and adjust as needed (NEVER commit .env)

# Host port to expose the STT API
FASTER_WHISPER_PORT=9001

# Whisper model to load (tiny / base / small / medium / large-v2 / large-v3)
# larger models = better accuracy, more VRAM
WHISPER_MODEL=large-v3

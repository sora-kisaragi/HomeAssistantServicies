# Qwen TTS environment variables
# Copy to .env and adjust as needed (NEVER commit .env)

# Host port to expose the TTS API
QWEN_TTS_PORT=9002

# HuggingFace model ID to load
# Options: Qwen/Qwen2.5-TTS-3B (smaller) / Qwen/Qwen2.5-TTS-7B (higher quality)
# Options:
#   Qwen/Qwen3-TTS-12Hz-1.7B-Base        (推奨 — 汎用 TTS)
#   Qwen/Qwen3-TTS-12Hz-0.6B-Base        (軽量・高速)
#   Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice (音声クローン — 別途検討 #10)
QWEN_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-Base

# HuggingFace access token — required for gated models (e.g. Qwen2.5-TTS)
# Generate at: https://huggingface.co/settings/tokens
# Must have "Read access to contents of all public gated repos you can access"
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
